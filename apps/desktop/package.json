{
  "name": "@dogebot/desktop",
  "version": "0.1.0",
  "description": "DogeBot Electron desktop client",
  "author": "DogeBot",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "native:build": "cd native/clipboard-addon && node-gyp rebuild",
    "native:clean": "cd native/clipboard-addon && node-gyp clean",
    "build": "tsc -p tsconfig.json && vite build && node scripts/copy-runtime-assets.cjs",
    "dev": "pnpm build && electron dist/main.js",
    "package:dir": "pnpm build && electron-builder --dir",
    "package:mac": "pnpm build && electron-builder --mac",
    "package:win": "pnpm native:build && pnpm build && electron-builder --win"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-json-view-lite": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^34.0.0",
    "electron-builder": "^26.15.0",
    "node-gyp": "11.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.dogebot.desktop",
    "productName": "DogeBot",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
